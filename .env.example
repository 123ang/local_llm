# AskAI Configuration

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/askai
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:YOUR_PASSWORD@localhost:5432/askai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=generate-a-strong-random-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PERSIST_DIR=./storage/chromadb

# File Storage
UPLOAD_DIR=./storage/uploads

# CORS
FRONTEND_URL=http://localhost:3000

# Super Admin (created on first run)
SUPER_ADMIN_EMAIL=admin@askai.local
SUPER_ADMIN_PASSWORD=admin123
